{
  "name": "sitepulse-hub-desktop-audit",
  "baseUrl": "http://127.0.0.1:4012",
  "serverCommand": "npm run dev -- --hostname 127.0.0.1 --port 4012",
  "serverCwd": "..",
  "routeLoadTimeoutMs": 40000,
  "buttonClickTimeoutMs": 4500,
  "clickWaitMs": 900,
  "viewportWidth": 1440,
  "viewportHeight": 900,
  "scrollEffectMinPx": 8,
  "sectionOrderWaitMs": 600,
  "maxRunMs": 180000,
  "checkpointEveryClicks": 10,
  "reportDir": "reports",
  "checkpointFile": "reports/sitepulse-hub-checkpoint.json",
  "requireButtonEffect": true,
  "allowedNoEffectButtonContains": [
    "import json file",
    "importar json",
    "checar api",
    "carregar exemplo"
  ],
  "ignoredRequestFailedErrors": [
    "ERR_ABORTED"
  ],
  "sectionOrderRules": [],
  "routes": [
    "/?autologin=1&selfaudit=1"
  ]
}
