{
  "name": "kuruma-site-mobile-audit",
  "baseUrl": "http://127.0.0.1:3111",
  "serverCommand": "npm run dev -- --hostname 127.0.0.1 --port 3111",
  "serverCwd": "..",
  "routeLoadTimeoutMs": 40000,
  "buttonClickTimeoutMs": 4500,
  "clickWaitMs": 1100,
  "viewportWidth": 390,
  "viewportHeight": 844,
  "scrollEffectMinPx": 6,
  "sectionOrderWaitMs": 1800,
  "maxRunMs": 180000,
  "checkpointEveryClicks": 10,
  "reportDir": "reports",
  "checkpointFile": "reports/kuruma-mobile-checkpoint.json",
  "requireButtonEffect": true,
  "allowedNoEffectButtonContains": [
    "whatsapp",
    "inici",
    "inicio",
    "home",
    "ir para slide"
  ],
  "ignoredRequestFailedErrors": [
    "ERR_ABORTED"
  ],
  "sectionOrderRules": [
    {
      "id": "faq-before-footer-mobile",
      "description": "No mobile, Infos + FAQ deve aparecer antes do footer.",
      "routes": [
        "/"
      ],
      "beforeSelector": "#service-details",
      "afterSelector": "#footer",
      "required": true
    }
  ],
  "routes": [
    "/"
  ]
}
