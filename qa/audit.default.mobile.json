{
  "name": "sitepulse-default-mobile-audit",
  "baseUrl": "http://127.0.0.1:3111",
  "serverCommand": "npm run dev -- --hostname 127.0.0.1 --port 3111",
  "serverCwd": "..",
  "routeLoadTimeoutMs": 40000,
  "buttonClickTimeoutMs": 4500,
  "clickWaitMs": 1100,
  "viewportWidth": 390,
  "viewportHeight": 844,
  "scrollEffectMinPx": 6,
  "sectionOrderWaitMs": 1400,
  "maxRunMs": 180000,
  "checkpointEveryClicks": 10,
  "reportDir": "reports",
  "checkpointFile": "reports/default-mobile-checkpoint.json",
  "autoDiscoverRoutes": true,
  "discoverFromSitemap": true,
  "discoverMenuLinks": true,
  "maxDiscoveredRoutes": 60,
  "requireButtonEffect": true,
  "allowedNoEffectButtonContains": [
    "whatsapp",
    "home",
    "menu"
  ],
  "ignoredRequestFailedErrors": [
    "ERR_ABORTED"
  ],
  "sectionOrderRules": [],
  "routes": [
    "/"
  ]
}
