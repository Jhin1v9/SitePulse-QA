{
  "name": "sitepulse-desktop",
  "version": "1.0.0",
  "private": true,
  "description": "Desktop-native audit workstation for SitePulse with local runtime, reports and command execution.",
  "author": "SitePulse",
  "type": "module",
  "main": "src/main.cjs",
  "scripts": {
    "sync:runtime": "node scripts/sync-runtime.mjs",
    "sync:runtime:fast": "node scripts/sync-runtime.mjs",
    "dev": "npm run build:os && npm run sync:runtime && set SITEPULSE_OS=1 && node scripts/run-electron.mjs .",
    "dev:v3": "npm run build:interface-v3 && npm run sync:runtime && node scripts/run-electron-v3.mjs",
    "build:os": "cd app && npm run build && cd .. && xcopy /E /I /Y app\\dist src\\app\\dist 2>nul || cp -r app/dist src/app/dist",
    "dev:os": "npm run build:os && npm run sync:runtime && set SITEPULSE_OS=1 && node scripts/run-electron.mjs .",
    "build:interface-v3": "node scripts/build-interface-v3.mjs",
    "smoke": "npm run sync:runtime && node scripts/run-electron.mjs . --smoke-test",
    "test:ui": "node scripts/ui-contract.mjs",
    "test:phase1-workspace": "node scripts/phase1-workspace-smoke.mjs",
    "test:buttons": "npm run sync:runtime && node scripts/run-electron.mjs . --button-test",
    "check": "npm run smoke && npm run test:ui",
    "pack:dir": "npm run sync:runtime && electron-builder --dir",
    "pack:dir:no-sign": "node scripts/pack-dir-no-sign.mjs",
    "build": "npm run pack:dir",
    "build:run": "node scripts/build-and-run.mjs",
    "build:win:staging": "npm run sync:runtime && electron-builder --win nsis-web zip --config.directories.output=dist-staging",
    "build:win": "npm run sync:runtime && electron-builder --win nsis-web zip",
    "build:update:metadata": "node scripts/build-version-json.mjs --output-dir dist-staging --notes \"SitePulse Studio desktop release.\"",
    "typecheck": "tsc --noEmit",
    "compile:ts": "tsc",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "@sparticuz/chromium": "138.0.2",
    "electron-updater": "6.6.2",
    "playwright": "^1.53.2",
    "react-router-dom": "^7.14.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "electron": "40.8.0",
    "electron-builder": "26.8.1",
    "jest": "^30.3.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "vite": "^8.0.3"
  },
  "build": {
    "appId": "com.sitepulse.desktop",
    "productName": "SitePulse Studio",
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://cdn.sitepulse.app/releases/"
      }
    ],
    "generateUpdatesFilesForAllChannels": true,
    "files": [
      {
        "from": "src",
        "to": "src",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "runtime-source",
        "to": "runtime-source",
        "filter": [
          "**/*"
        ]
      },
      "package.json"
    ],
    "extraMetadata": {
      "main": "src/main.cjs"
    },
    "asarUnpack": [
      "src/preload.cjs",
      "runtime-source/**",
      "node_modules/playwright/**",
      "node_modules/playwright-core/**",
      "node_modules/@sparticuz/**"
    ],
    "win": {
      "target": [
        "nsis-web",
        "zip"
      ],
      "artifactName": "SitePulse-Studio-${version}-Setup.${ext}"
    },
    "nsisWeb": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    }
  }
}
